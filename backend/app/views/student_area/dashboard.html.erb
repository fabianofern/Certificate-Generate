<div class="row mb-4">
  <div class="col-12">
    <h2 class="fw-bold mb-1">Meus Certificados</h2>
    <p class="text-muted">Abaixo estão listados todos os seus certificados de participação.</p>
  </div>
</div>

<% if @certificates.any? %>
  <div class="row g-4">
    <% @certificates.each do |certificate| %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden transition-hover">
          <div class="bg-primary bg-gradient p-3 text-white text-center">
            <i class="bi bi-patch-check-fill mb-2" style="font-size: 2.5rem;"></i>
            <h5 class="card-title fw-bold mb-0 text-truncate"><%= certificate.event.title %></h5>
          </div>
          <div class="card-body p-4">
            <div class="d-flex align-items-center mb-3 text-muted small">
              <i class="bi bi-clock me-2 text-primary"></i>
              <span><%= certificate.event.workload %> horas de carga horária</span>
            </div>
            <div class="d-flex align-items-center mb-3 text-muted small">
              <i class="bi bi-calendar3 me-2 text-primary"></i>
              <span><%= certificate.event.period %></span>
            </div>
            <div class="d-flex align-items-center mb-0 text-muted small">
              <i class="bi bi-calendar-check me-2 text-primary"></i>
              <span>Emitido em <%= certificate.created_at.strftime('%d/%m/%Y') %></span>
            </div>
            
            <hr class="my-3">
            
            <div class="d-flex justify-content-between align-items-center">
              <% if certificate.download_token_valid? %>
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Disponível</span>
              <% else %>
                <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Link Expirado</span>
              <% end %>
            </div>
          </div>
          <div class="card-footer bg-white border-0 p-3 pt-0 d-flex gap-2">
            <%= link_to student_area_certificate_path(certificate.uuid), class: 'btn btn-outline-primary w-100 rounded-3' do %>
              <i class="bi bi-eye me-1"></i> Visualizar
            <% end %>
            <% if certificate.download_token_valid? %>
              <%= link_to download_public_certificate_path(certificate.download_token), class: 'btn btn-primary w-100 rounded-3', data: { turbo: false } do %>
                <i class="bi bi-download me-1"></i> PDF
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card border-0 shadow-sm rounded-4 p-5 text-center">
    <div class="card-body">
      <div class="bg-light rounded-circle d-inline-flex p-4 mb-4">
        <i class="bi bi-file-earmark-x text-muted" style="font-size: 3rem;"></i>
      </div>
      <h4 class="fw-bold mb-3">Nenhum certificado encontrado</h4>
      <p class="text-muted mb-0">Você ainda não possui certificados gerados vinculados a este CPF/E-mail.</p>
    </div>
  </div>
<% end %>

<style>
  .transition-hover {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .transition-hover:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
  }
  .bg-gradient {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  }
  .btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
  }
  .btn-primary:hover {
    opacity: 0.9;
  }
</style>
