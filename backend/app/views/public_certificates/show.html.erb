<div class="card-body">
  <div class="mb-4">
    <i class="bi bi-patch-check-fill text-success fs-1"></i>
  </div>
  
  <h2 class="fw-bold mb-3">Seu Certificado está pronto!</h2>
  <p class="text-muted mb-4">Olá <strong><%= @certificate.participant.name %></strong>, seu certificado para o evento <strong><%= @certificate.event.title %></strong> já pode ser baixado.</p>
  
  <div class="alert alert-info bg-opacity-10 border-info text-info mb-4 text-start">
    <div class="d-flex">
      <i class="bi bi-info-circle-fill me-2"></i>
      <div>
        <small class="d-block fw-bold">Informações do Certificado:</small>
        <small class="d-block">• Evento: <%= @certificate.event.title %></small>
        <small class="d-block">• Carga Horária: <%= @certificate.event.workload %>h</small>
        <small class="d-block">• Data de Emissão: <%= @certificate.created_at.strftime('%d/%m/%Y') %></small>
      </div>
    </div>
  </div>

  <%= link_to download_public_certificate_path(@certificate.download_token), class: 'btn btn-download btn-lg text-white w-100 mb-3' do %>
    <i class="bi bi-file-earmark-pdf-fill me-2"></i>Baixar PDF
  <% end %>
  
  <p class="text-danger small mb-0">
    <i class="bi bi-clock-history me-1"></i>
    Este link expira em <%= (@certificate.created_at + 7.days).strftime('%d/%m/%Y às %H:%M') %>
  </p>
</div>
