<div class="row mb-4">
  <div class="col-12">
    <h2 class="fw-bold"><i class="bi bi-speedometer2 me-2"></i>Dashboard Operacional</h2>
    <p class="text-muted">Visão geral das suas tarefas e eventos ativos.</p>
  </div>
</div>

<!-- Estatísticas Rápidas -->
<div class="row g-4 mb-5">
  <div class="col-md-4">
    <div class="card stats-card h-100 border-start border-4 border-primary">
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
            <i class="bi bi-calendar-event text-primary fs-4"></i>
          </div>
          <div>
            <h6 class="card-subtitle text-muted mb-1">Total de Eventos</h6>
            <h3 class="card-title mb-0 fw-bold"><%= total_events %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card stats-card h-100 border-start border-4 border-warning">
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
            <i class="bi bi-envelope-exclamation text-warning fs-4"></i>
          </div>
          <div>
            <h6 class="card-subtitle text-muted mb-1">Pendentes de Envio</h6>
            <h3 class="card-title mb-0 fw-bold"><%= pending_certificates.count %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card stats-card h-100 border-start border-4 border-success">
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
            <i class="bi bi-send-check text-success fs-4"></i>
          </div>
          <div>
            <h6 class="card-subtitle text-muted mb-1">Certificados Enviados</h6>
            <h3 class="card-title mb-0 fw-bold"><%= certificates_sent %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row mb-5">
  <!-- Ações Rápidas -->
  <div class="col-12 mb-4">
    <h5 class="fw-bold mb-3">Ações Rápidas</h5>
    <div class="row g-3">
      <div class="col-md-3">
        <%= link_to new_event_path, class: 'btn btn-outline-primary w-100 py-3 rounded-3 d-flex flex-column align-items-center justify-content-center h-100' do %>
          <i class="bi bi-plus-circle fs-3 mb-2"></i>
          <span>Novo Evento</span>
        <% end %>
      </div>
      <div class="col-md-3">
        <%= link_to import_participants_path, class: 'btn btn-outline-success w-100 py-3 rounded-3 d-flex flex-column align-items-center justify-content-center h-100' do %>
          <i class="bi bi-file-earmark-arrow-up fs-3 mb-2"></i>
          <span>Importar Participantes</span>
        <% end %>
      </div>
      <div class="col-md-3">
        <%= link_to events_path, class: 'btn btn-outline-info w-100 py-3 rounded-3 d-flex flex-column align-items-center justify-content-center h-100' do %>
          <i class="bi bi-lightning-charge fs-3 mb-2"></i>
          <span>Gerar Certificados</span>
        <% end %>
      </div>
      <div class="col-md-3">
        <%= link_to certificates_path(status: 'pending'), class: 'btn btn-outline-warning w-100 py-3 rounded-3 d-flex flex-column align-items-center justify-content-center h-100' do %>
          <i class="bi bi-send fs-3 mb-2"></i>
          <span>Enviar Pendentes</span>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Eventos Recentes -->
  <div class="col-12">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-0">
        <h5 class="mb-0 fw-bold">Eventos Recentes</h5>
        <%= link_to 'Ver Todos', events_path, class: 'btn btn-sm btn-light text-primary' %>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Título</th>
                <th>Data</th>
                <th>Status (Gerados/Total)</th>
                <th class="text-end pe-4">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% recent_events.each do |event| %>
                <tr>
                  <td class="ps-4 fw-medium"><%= event.title %></td>
                  <td><%= event.created_at.strftime('%d/%m/%Y') %></td>
                  <td>
                    <% total = event.participants.count %>
                    <% generated = event.certificates.count %>
                    <span class="badge <%= generated == total ? 'bg-success' : 'bg-warning' %> bg-opacity-10 text-<%= generated == total ? 'success' : 'warning' %>">
                      <%= generated %>/<%= total %>
                    </span>
                  </td>
                  <td class="text-end pe-4">
                    <%= link_to event, class: 'btn btn-sm btn-light' do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to certificates_event_path(event), class: 'btn btn-sm btn-light text-primary' do %>
                      <i class="bi bi-patch-check"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
