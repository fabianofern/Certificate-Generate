<%= form_with(model: participant, local: true) do |f| %>
  <% if participant.errors.any? %>
    <div class="alert alert-danger border-0 shadow-sm mb-4">
      <div class="d-flex">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div>
          <h6 class="alert-heading fw-bold mb-1"><%= pluralize(participant.errors.count, "erro") %> impediram a gravação:</h6>
          <ul class="mb-0 small">
            <% participant.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Nome Completo", class: "form-label fw-bold small text-uppercase text-muted" %>
    <div class="input-group">
      <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
      <%= f.text_field :name, class: "form-control border-start-0 ps-0", placeholder: "Ex: João Silva", required: true %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :email, "E-mail", class: "form-label fw-bold small text-uppercase text-muted" %>
    <div class="input-group">
      <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
      <%= f.email_field :email, class: "form-control border-start-0 ps-0", placeholder: "joao@exemplo.com", required: true %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :cpf, "CPF", class: "form-label fw-bold small text-uppercase text-muted" %>
      <div class="input-group">
        <span class="input-group-text bg-light border-end-0"><i class="bi bi-card-text text-muted"></i></span>
        <%= f.text_field :cpf, class: "form-control border-start-0 ps-0 cpf-mask", placeholder: "000.000.000-00", required: true, maxlength: 14 %>
      </div>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :registration, "Matrícula", class: "form-label fw-bold small text-uppercase text-muted" %>
      <div class="input-group">
        <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash text-muted"></i></span>
        <%= f.text_field :registration, class: "form-control border-start-0 ps-0", placeholder: "Ex: 2024001" %>
      </div>
    </div>
  </div>
  
  <div class="mb-4 form-check form-switch">
    <%= f.check_box :active, class: "form-check-input", id: "participantActiveSwitch" %>
    <%= f.label :active, "Participante Ativo", class: "form-check-label fw-bold small text-uppercase text-muted", for: "participantActiveSwitch" %>
    <div class="form-text small">Participantes inativos não aparecem nas listagens principais nem recebem novos certificados.</div>
  </div>

  <div class="form-text small mb-4">O CPF e a Matrícula são usados para identificação e consulta.</div>

  <div class="d-grid gap-2">
    <%= f.submit "Salvar Alterações", class: "btn btn-primary py-2 fw-bold" %>
    <%= link_to "Cancelar", participants_path, class: "btn btn-light py-2 text-muted" %>
  </div>
<% end %>
