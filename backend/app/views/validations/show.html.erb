<div class="row justify-content-center mt-5">
  <div class="col-md-6 text-center">
    <% if @qr_data.blank? %>
      <div class="card shadow-sm border-0">
        <div class="card-body p-5">
          <i class="bi bi-qr-code text-primary" style="font-size: 4rem;"></i>
          <h2 class="mt-3 mb-3">Validação de Certificado</h2>
          <p class="text-muted">Aponte a câmera do seu celular para o QR Code impresso no certificado para validá-lo.</p>
        </div>
      </div>

    <% elsif @error %>
      <div class="alert alert-danger shadow-sm p-4">
        <i class="bi bi-exclamation-triangle-fill" style="font-size: 2rem;"></i>
        <h4 class="mt-2">Erro de Validação</h4>
        <p><%= @error %></p>
        <hr>
        <p class="mb-0 small">Certifique-se de que escaneou um QR Code válido gerado pelo nosso sistema.</p>
      </div>

    <% else %>
      <div class="card shadow border-success" style="border-top: 5px solid #198754;">
        <div class="card-body p-5">
          <div class="text-success mb-3">
            <i class="bi bi-patch-check-fill" style="font-size: 4rem;"></i>
          </div>
          <h2 class="mb-4 text-success">Certificado Válido!</h2>
          
          <div class="text-start bg-light p-4 rounded">
            <p><strong>Participante:</strong><br> <%= @certificate_info['participant_name'] %></p>
            <p><strong>Email:</strong><br> <%= @certificate_info['participant_email'] %></p>
            <p><strong>Evento:</strong><br> <%= @certificate_info['event_title'] %></p>
            <p><strong>Carga Horária:</strong><br> <%= @certificate_info['workload'] %> horas</p>
            <p><strong>Data de Emissão:</strong><br> <%= @certificate_info['issue_date'] %></p>
            <hr>
            <p class="small text-muted mb-0">ID: <%= @certificate_info['uuid'] %></p>
          </div>
        </div>
        <div class="card-footer bg-white text-muted small py-3">
          Verificado com sucesso em <%= Time.current.strftime('%d/%m/%Y %H:%M') %>.
          Este sistema verifica a integridade dos dados, funcionando inclusive de forma offline.
        </div>
      </div>
    <% end %>
  </div>
</div>
