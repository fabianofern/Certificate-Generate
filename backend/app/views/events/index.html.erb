<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Eventos</h1>
  <%= link_to 'Novo Evento', new_event_path, class: 'btn btn-primary' %>
</div>

<div class="row">
  <% @events.each do |event| %>
    <div class="col-md-6 col-lg-4 mb-4">
      <div class="card h-100 border-0 shadow-sm hover-shadow transition">
        <div class="card-body">
          <h5 class="card-title fw-bold text-dark mb-3"><%= event.title %></h5>
          
          <div class="mb-4">
            <div class="d-flex align-items-center mb-2 text-muted small">
              <i class="bi bi-clock me-2 text-primary"></i>
              <span><%= event.workload %> horas de carga horária</span>
            </div>
            <div class="d-flex align-items-center mb-2 text-muted small">
              <i class="bi bi-calendar3 me-2 text-primary"></i>
              <span><%= event.period %></span>
            </div>
            <div class="d-flex align-items-center mb-2 text-muted small">
              <i class="bi bi-geo-alt me-2 text-primary"></i>
              <span class="text-truncate"><%= event.location %></span>
            </div>
            <div class="d-flex align-items-center text-muted small">
              <i class="bi bi-person me-2 text-primary"></i>
              <span><%= event.instructor_name %></span>
            </div>
          </div>

          <div class="d-flex flex-wrap gap-2 pt-3 border-top">
            <%= link_to event_path(event), class: 'btn btn-outline-primary btn-sm d-inline-flex align-items-center' do %>
              <i class="bi bi-eye me-1"></i> Ver
            <% end %>
            <%= link_to edit_event_path(event), class: 'btn btn-outline-warning btn-sm d-inline-flex align-items-center' do %>
              <i class="bi bi-pencil me-1"></i> Editar
            <% end %>
            <%= link_to certificates_event_path(event), class: 'btn btn-outline-info btn-sm d-inline-flex align-items-center' do %>
              <i class="bi bi-patch-check me-1"></i> Certificados
            <% end %>
            <% if can_delete? %>
              <div class="ms-auto">
                <%= button_to event_path(event), method: :delete, 
                    class: 'btn btn-outline-danger btn-sm d-inline-flex align-items-center',
                    data: { confirm: 'Tem certeza?' } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
        <div class="card-footer bg-light border-0 py-2">
          <div class="d-flex justify-content-between align-items-center">
            <% total = event.participants.count %>
            <% generated = event.certificates.count %>
            <span class="badge <%= generated == total ? 'bg-success' : 'bg-warning' %> bg-opacity-10 text-<%= generated == total ? 'success' : 'warning' %> border border-<%= generated == total ? 'success' : 'warning' %> border-opacity-25">
              <%= generated %>/<%= total %> Certificados
            </span>
            <small class="text-muted"><i class="bi bi-clock-history me-1"></i><%= event.created_at.strftime('%d/%m/%y') %></small>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @events.empty? %>
  <div class="text-center py-5">
    <h4 class="text-muted">Nenhum evento cadastrado</h4>
    <%= link_to 'Criar primeiro evento', new_event_path, class: 'btn btn-primary mt-3' %>
  </div>
<% end %>